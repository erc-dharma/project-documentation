                     <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Latin</a:documentation>
                  </choice>
                  <choice>
                     <value>maturity:83207</value>
                     <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Early Brāhmī</a:documentation>
                     <value>maturity:early</value>
                     <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Early Brāhmī</a:documentation>
                     <value>maturity:83211</value>
                     <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Late Brāhmī</a:documentation>
                     <value>maturity:late</value>
                     <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Late Brāhmī</a:documentation>
                     <value>maturity:83209</value>
                     <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Middle Brāhmī</a:documentation>
                     <value>maturity:middle</value>
                     <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Middle Brāhmī</a:documentation>
                     <value>maturity:83213</value>
                     <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Regional Brāhmī-derived script</a:documentation>
                     <value>maturity:regional</value>
                     <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Regional Brāhmī-derived script</a:documentation>
                     <value>maturity:83215</value>
                     <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Vernacular Brāhmī-derived script</a:documentation>
                     <value>maturity:vernacular</value>
                     <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Vernacular Brāhmī-derived script</a:documentation>
                     <value>maturity:00000</value>
                     <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Undetermined</a:documentation>
                     <value>maturity:undetermined</value>
                     <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Undetermined</a:documentation>
                  </choice>
               </list>
            </attribute>
         </optional>
         <attribute name="type">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">characterizes the element in some sense, using any convenient classification scheme or typology.</a:documentation>
            <choice>
               <value>apparatus</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0"/>
               <value>bibliography</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0"/>
               <value>commentary</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0"/>
               <value>edition</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0"/>
               <value>textpart</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">boxlike partition</a:documentation>
               <value>translation</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0"/>
            </choice>
         </attribute>
         <optional>
            <attribute name="subtype">
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(subtype) provides a sub-categorization of the element, if needed.</a:documentation>
               <choice>
                  <value>fragment</value>
                  <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">for fragments bearing non-contiguous text</a:documentation>
                  <value>face</value>
                  <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">for a physically contiguous surface of a three-dimensional object of any shape and any number of sides</a:documentation>
                  <value>faces</value>
                  <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">in texts where each line of a textpart continues across two or more surfaces such as the frontal and lateral face of a four-sided stele</a:documentation>
                  <value>zone</value>
                  <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">for visually distinct zones on a single two-dimensional surface</a:documentation>
                  <value>column</value>
                  <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">for zones placed side by side and generally taller than they are wide (as in newspaper columns)</a:documentation>
                  <value>item</value>
                  <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">for physically distinct objects such as architectural elements, e.g. when an inscription is engraved on two pillars</a:documentation>
                  <value>trial</value>
                  <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">to explicitly flag short, often unintelligible, pieces of text outside the campus of the main inscription and presumably not visible when the inscription was displayed in its original setting, which you judge to be trial engravings</a:documentation>
               </choice>
            </attribute>
         </optional>
         <empty/>
      </element>
   </define>
   <define name="tei_att.global.facs.attributes">
      <ref name="tei_att.global.facs.attribute.facs"/>
   </define>
   <define name="tei_att.global.facs.attribute.facs">
      <optional>
         <attribute name="facs">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(facsimile) points to one or more images, portions of an image, or surfaces which correspond to the current element.</a:documentation>
            <list>
               <oneOrMore>
                  <data type="anyURI">
                     <param name="pattern">\S+</param>
                  </data>
               </oneOrMore>
            </list>
         </attribute>
      </optional>
   </define>
   <define name="tei_att.global.change.attributes">
      <ref name="tei_att.global.change.attribute.change"/>
   </define>
   <define name="tei_att.global.change.attribute.change">
      <optional>
         <attribute name="change">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">points to one or more <code xmlns="http://www.w3.org/1999/xhtml"
                     xmlns:rng="http://relaxng.org/ns/structure/1.0">&lt;change&gt;</code> elements documenting a state or revision campaign to which the element bearing this attribute and its children have been assigned by the encoder.</a:documentation>
            <list>
               <oneOrMore>
                  <data type="anyURI">
                     <param name="pattern">\S+</param>
                  </data>
               </oneOrMore>
            </list>
         </attribute>
      </optional>
   </define>
   <define name="tei_facsimile">
      <element name="facsimile">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">contains a representation of some written source in the form of a set of images rather than as transcribed or encoded text. [12.1. Digital Facsimiles]</a:documentation>
         <group>
            <choice>
               <oneOrMore>
                  <choice>
                     <ref name="tei_model.graphicLike"/>
                  </choice>
               </oneOrMore>
               <oneOrMore>
                  <ref name="tei_facsimile"/>
               </oneOrMore>
            </choice>
         </group>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  xmlns:rng="http://relaxng.org/ns/structure/1.0"
                  id="dharma-facsimile-no_facsimile_text_nodes-constraint-rule-46">
            <sch:rule xmlns="http://www.tei-c.org/ns/1.0"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:xs="http://www.w3.org/2001/XMLSchema"
                      context="tei:facsimile//tei:line | tei:facsimile//tei:zone">
               <sch:report test="child::text()[ normalize-space(.) ne '']">
          A facsimile element represents a text with images, thus
          transcribed text should not be present within it.
        </sch:report>
            </sch:rule>
         </pattern>
      </element>
   </define>
   <define name="tei_damage">
      <element name="damage">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(damage) contains an area of damage to the text witness. [12.3.3.1. Damage, Illegibility, and Supplied Text]</a:documentation>
         <oneOrMore>
            <choice>
               <ref name="tei_supplied"/>
               <ref name="tei_unclear"/>
               <ref name="tei_gap"/>
               <text/>
            </choice>
         </oneOrMore>
      </element>
   </define>
   <define name="tei_ex">
      <element name="ex">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(editorial expansion) contains a sequence of letters added by an editor or transcriber when expanding an abbreviation. [12.3.1.2. Abbreviation and Expansion]</a:documentation>
         <ref name="tei_macro.xtext"/>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  xmlns:rng="http://relaxng.org/ns/structure/1.0"
                  id="dharma-ex-ex-constraint-rule-47">
            <sch:rule xmlns="http://www.tei-c.org/ns/1.0"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:xs="http://www.w3.org/2001/XMLSchema"
                      context="tei:ex">
               <sch:report test="not(ancestor::tei:expan)">ex should only appear inside
                                    expan</sch:report>
               <sch:report test="parent::tei:abbr">ex should
                                    not be a child of abbr</sch:report>
            </sch:rule>
         </pattern>
         <ref name="tei_att.global.attribute.xmllang"/>
         <ref name="tei_att.global.rendition.attribute.rendition"/>
         <optional>
            <attribute name="cert">
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(certainty) signifies the degree of certainty associated with the intervention or interpretation.</a:documentation>
               <choice>
                  <value>low</value>
                  <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0"/>
               </choice>
            </attribute>
         </optional>
         <empty/>
      </element>
   </define>
   <define name="tei_fw">
      <element name="fw">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(forme work) contains a running head (e.g. a header, footer), catchword, or similar material appearing on the current page. [12.6. Headers, Footers, and Similar Matter]</a:documentation>
         <ref name="tei_macro.phraseSeq"/>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  xmlns:rng="http://relaxng.org/ns/structure/1.0"
                  id="dharma-fw-fw-after-pb-constraint-rule-48">
            <sch:rule xmlns="http://www.tei-c.org/ns/1.0"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:xs="http://www.w3.org/2001/XMLSchema"
                      context="tei:fw">
               <sch:report test="not(preceding-sibling::tei:pb[1] or preceding-sibling::tei:fw[1])"> The element fw must
                                    always be preceded by the element pb or by the element fw.
                                </sch:report>
            </sch:rule>
         </pattern>
         <attribute name="n">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(number) gives a number (or other label) for an element, which is not necessarily unique within the document.</a:documentation>
            <data type="string">
               <param name="pattern">[^ ]+</param>
            </data>
         </attribute>
         <optional>
            <attribute name="rend">
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(rendition) indicates how the element in question was rendered or presented in the source text.</a:documentation>
               <list>
                  <oneOrMore>
