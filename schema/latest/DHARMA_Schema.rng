   <define name="tei_note">
      <element name="note">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(note) contains a note or annotation. [3.9.1. Notes and Simple Annotation 2.2.6. The Notes Statement 3.12.2.8. Notes and Statement of Language 10.3.5.4. Notes within Entries]</a:documentation>
         <ref name="tei_macro.specialPara"/>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  xmlns:rng="http://relaxng.org/ns/structure/1.0"
                  id="dharma-note-note-constraint-rule-28">
            <sch:rule xmlns="http://www.tei-c.org/ns/1.0"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns:xs="http://www.w3.org/2001/XMLSchema"
                      context="tei:note">
               <sch:report test="ancestor::tei:note">notes cannot nest</sch:report>
               <sch:report test="ancestor::tei:div[@type='commentary'] and not(ancestor::tei:p or ancestor::tei:item)">Inside div[@type='commentary'], note should be wrapped inside a
                                    p or an item element</sch:report>
               <sch:report test="ancestor::tei:div[@type='apparatus'] and not(parent::tei:app)">Inside div[@type='apparatus'], note should be wrapped inside an
                                    app element. Please note that note(s) may not contain further
                                    notes.</sch:report>
               <sch:report test="ancestor::tei:div[@type='bibliography'] and not(ancestor::tei:p) and not(ancestor::tei:listBibl)">Inside div[@type='bibliography'], note should be wrapped inside
                                    an p element for the epigraphic lemma</sch:report>
               <sch:report test="parent::tei:bibl and ancestor::tei:listBibl and following-sibling::tei:*">Note should the last element of the
                                biliography</sch:report>
            </sch:rule>
            <sch:rule xmlns="http://www.tei-c.org/ns/1.0"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns:xs="http://www.w3.org/2001/XMLSchema"
                      context="tei:note[parent::tei:app]">
               <sch:report test="following-sibling::tei:*[not(local-name () = 'note')]">Note(s) be should the last element of the apparatus
                                    entry</sch:report>
            </sch:rule>
            <sch:rule xmlns="http://www.tei-c.org/ns/1.0"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns:xs="http://www.w3.org/2001/XMLSchema"
                      context="tei:note">
               <sch:report test="child::tei:note">Note(s) may not contain
                                    further notes (this is not a technical requirement but a
                                    convention we shall observe to reduce
                                complication)</sch:report>
            </sch:rule>
         </pattern>
         <ref name="tei_att.cmc.attributes"/>
         <ref name="tei_att.typed.attribute.type"/>
         <optional>
            <attribute name="xml:lang">
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(language) indicates the language of the element content using a tag generated according to <a xmlns="http://www.w3.org/1999/xhtml"
                     xmlns:rng="http://relaxng.org/ns/structure/1.0"
                     href="http://www.rfc-editor.org/rfc/bcp/bcp47.txt">BCP 47</a>.</a:documentation>
               <choice>
                  <value>ara</value>
                  <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Arabic</a:documentation>
                  <value>ban</value>
                  <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Balinese</a:documentation>
